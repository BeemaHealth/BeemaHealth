# Frontend (Vite / TanStack Start)
VITE_API_URL=http://localhost:8000/api

# Backend — copy to .env at repo root or backend/.env
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgres://aretide:aretide@localhost:5432/aretide
# CORS = Cross-Origin Resource Sharing
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Hosting target: local | heroku_shield | aws (Amazon Web Services)
HOSTING_TARGET=local

# Production only — AWS (Amazon Web Services) S3 (Simple Storage Service) for document uploads
# SSE-KMS = Server-Side Encryption with AWS Key Management Service
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-west-2
DATABASE_SSL_REQUIRE=true
SECURE_SSL_REDIRECT=true
