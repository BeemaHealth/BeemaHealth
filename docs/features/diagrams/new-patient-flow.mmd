flowchart TB
  subgraph patient [Patient on Aretide]
    P1[Intake + consent]
  end

  subgraph aretide [Aretide backend]
    A1[Freeze payload + masterId]
    A2[Visit payment planned]
    WebhookRx["POST /api/webhooks/beluga/"]
  end

  subgraph outbound [Aretide POST to Beluga]
    O1[POST CREATION_PATH]
    O2[POST PHOTO_ENDPOINT]
  end

  subgraph beluga [Beluga Health]
    B1[Provider review]
    B2[Route Rx to pharmacy]
    WH[Webhook dispatcher]
  end

  P1 --> A1 --> A2 --> O1
  O1 -->|photo required| O2 --> B1
  O1 -->|no photo| B1
  B1 --> WH
  WH -->|DOCTOR_CHAT CS_MESSAGE RX_WRITTEN CONSULT_*| WebhookRx
  B1 --> B2
  B2 --> WH
  WH -->|PHARMACY_ORDER_* PACKAGE_*| WebhookRx
